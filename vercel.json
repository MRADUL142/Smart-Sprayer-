{
  "functions": {
    "api/index.py": {
      "runtime": "python3.9",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "buildCommand": "cd smart-sprayer/frontend && npm install && npm run build",
  "outputDirectory": "smart-sprayer/frontend/build",
  "env": {
    "PYTHONPATH": "/var/task/smart-sprayer"
  }
}
